Options -MultiViews
RewriteEngine On
RewriteBase /

# Serve existing files and folders as-is.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Clean book URLs:
# /perbandingan-administrasi-negara -> /detail.html
RewriteRule ^([a-z0-9-]+)/?$ /detail.html [L,QSA]
